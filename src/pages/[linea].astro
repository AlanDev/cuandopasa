---
import BaseLayout from "../layouts/BaseLayout.astro";
import HorarioViewer from "../components/HorarioViewer.astro";
import { recorridos, getRecorridoById } from "../data/recorridos";

export function getStaticPaths() {
  return recorridos.map((recorrido) => ({
    params: { linea: recorrido.id }
  }));
}

const { linea } = Astro.params;
const recorrido = getRecorridoById(linea ?? "");

if (!recorrido) {
  throw new Error(`Recorrido no encontrado: ${linea}`);
}
---

<BaseLayout title={`Horarios ${recorrido.nombre} – Chaco – Corrientes`}>
  <a
    href="/"
    class="inline-flex items-center gap-2 rounded-full border border-slate-700 bg-slate-900/70 px-4 py-2 text-sm font-medium text-slate-100 shadow-sm shadow-black/40 transition hover:border-sky-400 hover:bg-slate-900 sm:px-5 sm:py-2.5 sm:text-base"
  >
    <span class="text-lg">←</span>
    <span>Volver al inicio</span>
  </a>

  <div class="mt-6 sm:mt-8">
    <HorarioViewer nombreRecorrido={recorrido.nombre} tablas={recorrido.tablas} />
  </div>
</BaseLayout>

