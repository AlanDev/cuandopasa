---
import type { Recorrido } from "../data/recorridos";

interface Props {
  recorrido: Recorrido;
}

const { recorrido } = Astro.props;

const busqueda = `${recorrido.nombre} ${recorrido.palabrasClave.join(" ")}`.toLowerCase();
---

<a
  href={`/${recorrido.id}`}
  class="block rounded-2xl border border-slate-700 bg-slate-900/70 p-4 shadow-sm shadow-black/40 transition hover:-translate-y-0.5 hover:border-sky-400 hover:bg-slate-900 hover:shadow-lg focus-visible:border-sky-400 sm:p-5"
  data-recorrido-nombre={busqueda}
>
  <div class="flex items-center justify-between gap-4">
    <div>
      <h2 class="text-lg font-semibold text-slate-50 sm:text-xl">
        {recorrido.nombre}
      </h2>
      {recorrido.descripcion && (
        <p class="mt-1 text-sm text-slate-300 sm:text-base">
          {recorrido.descripcion}
        </p>
      )}
    </div>
    <span class="inline-flex h-10 w-10 flex-none items-center justify-center rounded-full bg-sky-500 text-lg font-bold text-slate-950 sm:h-11 sm:w-11">
      →
    </span>
  </div>
</a>

